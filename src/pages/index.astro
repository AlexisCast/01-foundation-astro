---
import MainLayout from "../layouts/MainLayout.astro";

// Server Only
const name = "Bazz Buzz";
const title = "Home Page";
---

<MainLayout title="Home Page">
	<h1>{name}</h1>

	<p>Actual time: {new Date().toLocaleTimeString()}</p>
	<p id="current-time">Actual time(real):</p>

	<footer>Year 2023</footer>

	<script>
		// Client Only
		const footer = document.querySelector("footer") as HTMLHtmlElement;
		const currentTimeParagraph = document.querySelector(
			"#current-time"
		) as HTMLParagraphElement;

		const currentYear: number = new Date().getFullYear();
		const currentLocalTime: string = new Date().toLocaleTimeString();

		footer.innerText = `Year ${currentYear}`;
		currentTimeParagraph.innerText = `Actual time(real): ${currentLocalTime}`;
	</script>
</MainLayout>
